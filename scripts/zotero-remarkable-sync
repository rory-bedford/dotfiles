#!/usr/bin/env python3
"""
zotero-remarkable-sync

Sync PDFs from a local Zotero library to a reMarkable tablet via SCP.
Reads zotero.sqlite directly (no Zotero API needed), tracks sync state
locally, and handles uploads and deletions.

PDFs are placed in a folder hierarchy mirroring Zotero collections, all
under a root "Zotero" folder. Documents are named as:
    Author(s) (Year) - Title

Requirements: ssh/scp access to reMarkable (SSH config alias "remarkable")
Dependencies: Python 3.9+ standard library only

Usage:
    zotero-remarkable-sync              # sync (upload new, delete removed)
    zotero-remarkable-sync --dry-run    # preview without changes
    zotero-remarkable-sync --force      # re-upload everything
    zotero-remarkable-sync --status     # show current sync state
"""

import argparse
import json
import re
import shutil
import sqlite3
import subprocess
import sys
import tempfile
import uuid
from datetime import datetime
from pathlib import Path

# --- Configuration -----------------------------------------------------------

ZOTERO_DIR = Path.home() / "Zotero"
ZOTERO_DB = ZOTERO_DIR / "zotero.sqlite"
ZOTERO_STORAGE = ZOTERO_DIR / "storage"

STATE_DIR = Path.home() / ".local" / "share" / "zotero-remarkable"
STATE_FILE = STATE_DIR / "state.json"

REMARKABLE_HOST = "remarkable"
REMARKABLE_XOCHITL = "/home/root/.local/share/remarkable/xochitl"

ROOT_FOLDER_NAME = "Library"

# --- Zotero database reading -------------------------------------------------


def open_zotero_db() -> sqlite3.Connection:
    """Copy and open zotero.sqlite read-only to avoid lock contention."""
    if not ZOTERO_DB.exists():
        print(f"Error: Zotero database not found at {ZOTERO_DB}", file=sys.stderr)
        sys.exit(1)

    tmp_db = Path(tempfile.mktemp(suffix=".sqlite"))
    shutil.copy2(ZOTERO_DB, tmp_db)
    for suffix in ("-wal", "-shm"):
        src = ZOTERO_DB.parent / (ZOTERO_DB.name + suffix)
        if src.exists():
            shutil.copy2(src, tmp_db.parent / (tmp_db.name + suffix))

    conn = sqlite3.connect(f"file:{tmp_db}?mode=ro", uri=True)
    conn.row_factory = sqlite3.Row

    return conn, tmp_db


def close_zotero_db(conn: sqlite3.Connection, tmp_db: Path):
    conn.close()
    tmp_db.unlink(missing_ok=True)
    for suffix in ("-wal", "-shm"):
        (tmp_db.parent / (tmp_db.name + suffix)).unlink(missing_ok=True)


def format_authors(conn: sqlite3.Connection, parent_item_id: int) -> str:
    """Get formatted author string for an item.

    Returns: "Smith", "Smith & Jones", or "Smith et al." style string.
    """
    query = """
        SELECT c.lastName
        FROM itemCreators ic
        JOIN creators c ON c.creatorID = ic.creatorID
        JOIN creatorTypes ct ON ct.creatorTypeID = ic.creatorTypeID
        WHERE ic.itemID = ?
          AND ct.creatorType = 'author'
        ORDER BY ic.orderIndex
    """
    authors = [row["lastName"] for row in conn.execute(query, (parent_item_id,))]

    if not authors:
        # Fall back to editors if no authors
        query_editors = """
            SELECT c.lastName
            FROM itemCreators ic
            JOIN creators c ON c.creatorID = ic.creatorID
            JOIN creatorTypes ct ON ct.creatorTypeID = ic.creatorTypeID
            WHERE ic.itemID = ?
              AND ct.creatorType = 'editor'
            ORDER BY ic.orderIndex
        """
        authors = [row["lastName"] for row in conn.execute(query_editors, (parent_item_id,))]

    if not authors:
        return "Unknown"
    elif len(authors) == 1:
        return authors[0]
    elif len(authors) == 2:
        return f"{authors[0]} & {authors[1]}"
    else:
        return f"{authors[0]} et al."


def get_year(conn: sqlite3.Connection, parent_item_id: int) -> str:
    """Get publication year for an item."""
    query = """
        SELECT idv.value
        FROM itemData id
        JOIN itemDataValues idv ON idv.valueID = id.valueID
        JOIN fields f ON f.fieldID = id.fieldID
        WHERE id.itemID = ?
          AND f.fieldName = 'date'
    """
    row = conn.execute(query, (parent_item_id,)).fetchone()
    if row and row["value"]:
        match = re.search(r"\b(19|20)\d{2}\b", row["value"])
        if match:
            return match.group()
    return ""


def format_visible_name(authors: str, year: str, title: str) -> str:
    """Format document name as 'Author(s) (Year) - Title'."""
    if year:
        return f"{authors} ({year}) - {title}"
    else:
        return f"{authors} - {title}"


def get_collections(conn: sqlite3.Connection) -> dict:
    """Get all Zotero collections and their hierarchy.

    Returns: {
        collectionID: {
            "name": str,
            "parent_id": int | None,
            "key": str,
        }
    }
    """
    query = """
        SELECT collectionID, collectionName, parentCollectionID, key
        FROM collections
        WHERE libraryID = 1
    """
    collections = {}
    for row in conn.execute(query):
        collections[row["collectionID"]] = {
            "name": row["collectionName"],
            "parent_id": row["parentCollectionID"],
            "key": row["key"],
        }
    return collections


def get_item_collections(conn: sqlite3.Connection) -> dict:
    """Map parent item IDs to their collection IDs.

    Returns: {parentItemID: [collectionID, ...]}
    """
    query = """
        SELECT ci.collectionID, ci.itemID
        FROM collectionItems ci
        WHERE ci.itemID NOT IN (SELECT itemID FROM deletedItems)
    """
    mapping = {}
    for row in conn.execute(query):
        mapping.setdefault(row["itemID"], []).append(row["collectionID"])
    return mapping


def collection_path(collections: dict, collection_id: int) -> list[int]:
    """Get the chain of collection IDs from root to this collection."""
    path = []
    current = collection_id
    seen = set()
    while current is not None and current not in seen:
        seen.add(current)
        path.append(current)
        current = collections[current]["parent_id"] if current in collections else None
    path.reverse()
    return path


def get_zotero_pdfs(conn: sqlite3.Connection) -> dict:
    """Query zotero.sqlite for all items with PDF attachments.

    Returns dict: {
        attachment_key: {
            "title": str,
            "visible_name": str,
            "path": str,
            "collection_path": [collectionID, ...] | None,
        }
    }
    """
    collections = get_collections(conn)
    item_collections = get_item_collections(conn)

    query = """
        SELECT
            items.key           AS attachment_key,
            ia.parentItemID     AS parent_item_id,
            idv.value           AS title,
            ia.path             AS attachment_path
        FROM itemAttachments ia
        JOIN items          ON items.itemID = ia.itemID
        JOIN itemData id    ON id.itemID = ia.parentItemID
        JOIN itemDataValues idv ON idv.valueID = id.valueID
        JOIN fields f       ON f.fieldID = id.fieldID
        WHERE f.fieldName = 'title'
          AND ia.contentType = 'application/pdf'
          AND ia.parentItemID IS NOT NULL
          AND items.itemID NOT IN (SELECT itemID FROM deletedItems)
          AND ia.parentItemID NOT IN (SELECT itemID FROM deletedItems)
    """

    results = {}
    for row in conn.execute(query):
        att_key = row["attachment_key"]
        path = row["attachment_path"]
        if not (path and path.startswith("storage:")):
            continue

        filename = path[len("storage:"):]
        full_path = ZOTERO_STORAGE / att_key / filename
        if not full_path.exists():
            continue

        parent_id = row["parent_item_id"]
        title = row["title"]
        authors = format_authors(conn, parent_id)
        year = get_year(conn, parent_id)
        visible_name = format_visible_name(authors, year, title)

        # Use first collection if item is in multiple
        coll_ids = item_collections.get(parent_id, [])
        coll_path = collection_path(collections, coll_ids[0]) if coll_ids else None

        results[att_key] = {
            "title": title,
            "visible_name": visible_name,
            "path": str(full_path),
            "collection_path": coll_path,
        }

    return results


def get_all_needed_collections(
    zotero_pdfs: dict, collections: dict
) -> dict[int, dict]:
    """Get collections that contain PDFs (directly or as ancestors)."""
    needed = {}
    for info in zotero_pdfs.values():
        if info["collection_path"]:
            for coll_id in info["collection_path"]:
                if coll_id not in needed and coll_id in collections:
                    needed[coll_id] = collections[coll_id]
    return needed


# --- State management --------------------------------------------------------


def load_state() -> dict:
    """Load sync state from disk."""
    if STATE_FILE.exists():
        return json.loads(STATE_FILE.read_text())
    return {"root_folder_uuid": None, "folders": {}, "items": {}}


def save_state(state: dict):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2))


# --- reMarkable operations ---------------------------------------------------


def scp_files(local_files: list[Path], remote_dir: str):
    """SCP a list of local files to a remote directory."""
    target = f"{REMARKABLE_HOST}:{remote_dir}/"
    subprocess.run(
        ["scp", "-q"] + [str(f) for f in local_files] + [target],
        check=True,
    )


def now_ms() -> str:
    return str(int(datetime.now().timestamp() * 1000))


def create_rm_folder(name: str, parent_uuid: str) -> str:
    """Create a folder on the reMarkable. Returns its UUID."""
    folder_uuid = str(uuid.uuid4())

    with tempfile.TemporaryDirectory() as tmpdir:
        tmpdir = Path(tmpdir)

        metadata = {
            "deleted": False,
            "lastModified": now_ms(),
            "lastOpened": "",
            "metadatamodified": False,
            "modified": False,
            "parent": parent_uuid,
            "pinned": False,
            "synced": False,
            "type": "CollectionType",
            "version": 0,
            "visibleName": name,
        }
        (tmpdir / f"{folder_uuid}.metadata").write_text(json.dumps(metadata, indent=4))
        (tmpdir / f"{folder_uuid}.content").write_text("{}")

        scp_files(list(tmpdir.iterdir()), REMARKABLE_XOCHITL)

    return folder_uuid


def ensure_root_folder(state: dict) -> str:
    """Ensure the root Zotero folder exists on the reMarkable."""
    if state["root_folder_uuid"]:
        return state["root_folder_uuid"]

    print(f"  Creating root folder: {ROOT_FOLDER_NAME}")
    folder_uuid = create_rm_folder(ROOT_FOLDER_NAME, "")
    state["root_folder_uuid"] = folder_uuid
    return folder_uuid


def ensure_collection_folders(
    state: dict,
    needed_collections: dict[int, dict],
    all_collections: dict,
) -> dict[int, str]:
    """Ensure all needed Zotero collections exist as folders on the reMarkable.

    Returns: {zotero_collectionID: reMarkable_folder_UUID}
    """
    folders = state.setdefault("folders", {})
    root_uuid = state["root_folder_uuid"]

    # Process in hierarchy order (parents before children)
    def sort_key(coll_id):
        return len(collection_path(all_collections, coll_id))

    for coll_id in sorted(needed_collections, key=sort_key):
        str_id = str(coll_id)
        if str_id in folders:
            continue

        coll = needed_collections[coll_id]
        parent_id = coll["parent_id"]

        # If a top-level collection has the same name as the root folder,
        # map it to the root folder instead of creating a subfolder
        is_top_level = parent_id is None or parent_id not in needed_collections
        if is_top_level and coll["name"] == ROOT_FOLDER_NAME:
            folders[str_id] = root_uuid
            continue

        if parent_id and str(parent_id) in folders:
            parent_uuid = folders[str(parent_id)]
        else:
            parent_uuid = root_uuid

        print(f"  Creating folder: {coll['name']}")
        rm_uuid = create_rm_folder(coll["name"], parent_uuid)
        folders[str_id] = rm_uuid

    return {int(k): v for k, v in folders.items()}


def get_document_parent_uuid(
    collection_path_ids: list[int] | None,
    folder_map: dict[int, str],
    root_uuid: str,
) -> str:
    """Determine which reMarkable folder a document should go in."""
    if collection_path_ids:
        leaf_id = collection_path_ids[-1]
        if leaf_id in folder_map:
            return folder_map[leaf_id]
    return root_uuid


def upload_pdf(pdf_path: str, visible_name: str, rm_uuid: str, parent_uuid: str):
    """Upload a PDF to the reMarkable with metadata files."""
    with tempfile.TemporaryDirectory() as tmpdir:
        tmpdir = Path(tmpdir)

        shutil.copy2(pdf_path, tmpdir / f"{rm_uuid}.pdf")

        metadata = {
            "deleted": False,
            "lastModified": now_ms(),
            "lastOpened": "",
            "lastOpenedPage": 0,
            "metadatamodified": False,
            "modified": False,
            "parent": parent_uuid,
            "pinned": False,
            "synced": False,
            "type": "DocumentType",
            "version": 0,
            "visibleName": visible_name,
        }
        (tmpdir / f"{rm_uuid}.metadata").write_text(json.dumps(metadata, indent=4))

        content = {
            "dummyDocument": False,
            "extraMetadata": {},
            "fileType": "pdf",
            "fontName": "",
            "lastOpenedPage": 0,
            "legacyEpub": False,
            "lineHeight": -1,
            "margins": 100,
            "orientation": "portrait",
            "pageCount": 0,
            "textScale": 1,
            "transform": {
                "m11": 1, "m12": 0, "m13": 0,
                "m21": 0, "m22": 1, "m23": 0,
                "m31": 0, "m32": 0, "m33": 1,
            },
        }
        (tmpdir / f"{rm_uuid}.content").write_text(json.dumps(content, indent=4))

        scp_files(list(tmpdir.iterdir()), REMARKABLE_XOCHITL)


def delete_from_remarkable(rm_uuid: str):
    """Delete all files for a document UUID from the reMarkable."""
    cmd = f"rm -rf {REMARKABLE_XOCHITL}/{rm_uuid}*"
    subprocess.run(["ssh", REMARKABLE_HOST, cmd], check=True)


def update_metadata_field(rm_uuid: str, updates: dict):
    """Update fields in a document's .metadata on the reMarkable."""
    remote_meta = f"{REMARKABLE_XOCHITL}/{rm_uuid}.metadata"

    result = subprocess.run(
        ["ssh", REMARKABLE_HOST, f"cat {remote_meta}"],
        capture_output=True, text=True, check=True,
    )
    metadata = json.loads(result.stdout)
    metadata.update(updates)
    metadata["lastModified"] = now_ms()

    with tempfile.TemporaryDirectory() as tmpdir:
        tmpdir = Path(tmpdir)
        meta_file = tmpdir / f"{rm_uuid}.metadata"
        meta_file.write_text(json.dumps(metadata, indent=4))
        scp_files([meta_file], REMARKABLE_XOCHITL)


def restart_xochitl():
    print("Restarting xochitl...")
    subprocess.run(["ssh", REMARKABLE_HOST, "systemctl restart xochitl"], check=True)


# --- Sync logic --------------------------------------------------------------


def sync(dry_run: bool = False, force: bool = False):
    print("Reading Zotero library...")
    conn, tmp_db = open_zotero_db()

    try:
        zotero_pdfs = get_zotero_pdfs(conn)
        all_collections = get_collections(conn)
    finally:
        close_zotero_db(conn, tmp_db)

    print(f"Found {len(zotero_pdfs)} PDFs in Zotero.")

    state = load_state()
    items = state["items"]

    if force:
        items.clear()
        state["folders"] = {}
        state["root_folder_uuid"] = None

    zotero_keys = set(zotero_pdfs.keys())
    state_keys = set(items.keys())

    to_upload = zotero_keys - state_keys
    to_delete = state_keys - zotero_keys

    # Detect title or folder changes
    to_update = set()
    for k in zotero_keys & state_keys:
        z = zotero_pdfs[k]
        s = items[k]
        if z["visible_name"] != s["visible_name"]:
            to_update.add(k)
        elif z["collection_path"] != s.get("collection_path"):
            to_update.add(k)

    if not to_upload and not to_delete and not to_update:
        print("Everything in sync.")
        return

    print(f"\n  Upload:  {len(to_upload)} new")
    print(f"  Delete:  {len(to_delete)} removed")
    print(f"  Update:  {len(to_update)} changed")

    if dry_run:
        # Build folder tree showing where everything goes
        needed = get_all_needed_collections(zotero_pdfs, all_collections)
        tree: dict[str | None, list] = {}  # parent_coll_id -> [(name, coll_id)]

        # Group collections by parent
        for coll_id, coll in needed.items():
            parent = coll["parent_id"] if coll["parent_id"] in needed else None
            tree.setdefault(parent, []).append((coll["name"], coll_id))

        # Group PDFs by their leaf collection
        pdfs_by_coll: dict[int | None, list] = {}
        for key in to_upload:
            info = zotero_pdfs[key]
            cp = info["collection_path"]
            leaf = cp[-1] if cp else None
            pdfs_by_coll.setdefault(leaf, []).append(info)

        def print_tree(parent_id, indent=1):
            prefix = "  " * indent
            for name, coll_id in sorted(tree.get(parent_id, []), key=lambda x: x[0]):
                print(f"{prefix}{name}/")
                # PDFs in this collection
                for info in sorted(pdfs_by_coll.get(coll_id, []), key=lambda x: x["visible_name"]):
                    size_mb = Path(info["path"]).stat().st_size / (1024 * 1024)
                    print(f"{prefix}  {info['visible_name']}  ({size_mb:.1f} MB)")
                print_tree(coll_id, indent + 1)

        print(f"\nFolder structure on reMarkable:")
        print(f"  {ROOT_FOLDER_NAME}/")
        print_tree(None)
        # PDFs not in any collection
        for info in sorted(pdfs_by_coll.get(None, []), key=lambda x: x["visible_name"]):
            size_mb = Path(info["path"]).stat().st_size / (1024 * 1024)
            print(f"    {info['visible_name']}  ({size_mb:.1f} MB)")

        if to_upload:
            total_bytes = sum(
                Path(zotero_pdfs[k]["path"]).stat().st_size for k in to_upload
            )
            total_gb = total_bytes / (1024 ** 3)
            if total_gb >= 1:
                print(f"\n  Total to transfer: {total_gb:.2f} GB ({len(to_upload)} files)")
            else:
                print(f"\n  Total to transfer: {total_bytes / (1024 ** 2):.1f} MB ({len(to_upload)} files)")
        if to_delete:
            print("\nWould delete:")
            for key in sorted(to_delete, key=lambda k: items[k]["visible_name"]):
                print(f"  - {items[key]['visible_name']}")
        if to_update:
            print("\nWould update:")
            for key in sorted(to_update, key=lambda k: zotero_pdfs[k]["visible_name"]):
                old = items[key]["visible_name"]
                new = zotero_pdfs[key]["visible_name"]
                print(f"  ~ {old}  ->  {new}")
        return

    # Ensure folder hierarchy
    root_uuid = ensure_root_folder(state)
    needed_collections = get_all_needed_collections(zotero_pdfs, all_collections)
    folder_map = ensure_collection_folders(state, needed_collections, all_collections)

    # Upload new PDFs
    for key in to_upload:
        info = zotero_pdfs[key]
        rm_uuid = str(uuid.uuid4())
        parent_uuid = get_document_parent_uuid(
            info["collection_path"], folder_map, root_uuid,
        )
        print(f"  Uploading: {info['visible_name']}")
        upload_pdf(info["path"], info["visible_name"], rm_uuid, parent_uuid)
        items[key] = {
            "uuid": rm_uuid,
            "visible_name": info["visible_name"],
            "collection_path": info["collection_path"],
        }

    # Delete removed PDFs
    for key in to_delete:
        info = items[key]
        print(f"  Deleting:  {info['visible_name']}")
        delete_from_remarkable(info["uuid"])
        del items[key]

    # Update changed items
    for key in to_update:
        z = zotero_pdfs[key]
        s = items[key]
        rm_uuid = s["uuid"]

        updates = {}
        if z["visible_name"] != s["visible_name"]:
            updates["visibleName"] = z["visible_name"]
        if z["collection_path"] != s.get("collection_path"):
            parent_uuid = get_document_parent_uuid(
                z["collection_path"], folder_map, root_uuid,
            )
            updates["parent"] = parent_uuid

        if updates:
            print(f"  Updating:  {z['visible_name']}")
            update_metadata_field(rm_uuid, updates)

        items[key] = {
            "uuid": rm_uuid,
            "visible_name": z["visible_name"],
            "collection_path": z["collection_path"],
        }

    save_state(state)
    print(f"\nDone. Uploaded: {len(to_upload)}, Deleted: {len(to_delete)}, "
          f"Updated: {len(to_update)}")

    restart_xochitl()


def show_status():
    state = load_state()
    items = state["items"]
    if not items:
        print("No synced items.")
        return
    print(f"{len(items)} items synced to reMarkable:\n")
    for key, info in sorted(items.items(), key=lambda x: x[1]["visible_name"]):
        print(f"  {info['visible_name']}")
        print(f"    zotero: {key}  rm: {info['uuid']}")


# --- CLI ---------------------------------------------------------------------


def main():
    parser = argparse.ArgumentParser(
        description="Sync Zotero PDFs to reMarkable via SCP.",
    )
    parser.add_argument(
        "--dry-run", "-n", action="store_true",
        help="Preview changes without uploading or deleting",
    )
    parser.add_argument(
        "--force", "-f", action="store_true",
        help="Re-upload everything (ignores current state)",
    )
    parser.add_argument(
        "--status", "-s", action="store_true",
        help="Show current sync state",
    )
    args = parser.parse_args()

    if args.status:
        show_status()
    else:
        sync(dry_run=args.dry_run, force=args.force)


if __name__ == "__main__":
    main()
